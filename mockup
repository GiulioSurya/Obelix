<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OBELIX Tracer</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600&family=Syne:wght@400;600;700;800&display=swap');

  :root {
    --bg: #0d0f14;
    --surface: #13161e;
    --surface2: #1a1e28;
    --border: #252a38;
    --border2: #2e3447;
    --text: #e2e8f0;
    --muted: #6b7894;
    --accent: #4f8ef7;
    --accent-dim: rgba(79,142,247,0.12);
    --green: #34d399;
    --green-dim: rgba(52,211,153,0.12);
    --orange: #fb923c;
    --orange-dim: rgba(251,146,60,0.1);
    --purple: #a78bfa;
    --purple-dim: rgba(167,139,250,0.12);
    --red: #f87171;
    --red-dim: rgba(248,113,113,0.1);
    --yellow: #fbbf24;
    --human: #60a5fa;
    --human-dim: rgba(96,165,250,0.1);
    --assistant: #34d399;
    --assistant-dim: rgba(52,211,153,0.1);
  }

  * { box-sizing:border-box; margin:0; padding:0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    min-height: 100vh;
    overflow: hidden;
  }

  .app {
    display: grid;
    grid-template-rows: 48px 1fr;
    grid-template-columns: 330px 1fr;
    height: 100vh;
  }

  /* в”Ђв”Ђ TOPBAR в”Ђв”Ђ */
  .topbar {
    grid-column: 1 / -1;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    padding: 0 20px;
    gap: 16px;
  }
  .logo { font-family:'Syne',sans-serif; font-weight:800; font-size:15px; letter-spacing:0.08em; color:var(--accent); text-transform:uppercase; }
  .logo span { color:var(--muted); font-weight:400; }
  .topbar-sep { width:1px; height:20px; background:var(--border); }
  .run-id { color:var(--muted); font-size:11px; }
  .run-id b { color:var(--text); }
  .badge { display:inline-flex; align-items:center; gap:5px; padding:2px 8px; border-radius:4px; font-size:10px; font-weight:600; letter-spacing:0.05em; text-transform:uppercase; }
  .badge-success { background:var(--green-dim); color:var(--green); border:1px solid rgba(52,211,153,0.2); }
  .topbar-right { margin-left:auto; display:flex; align-items:center; gap:12px; color:var(--muted); font-size:11px; }
  .metric { display:flex; flex-direction:column; align-items:flex-end; }
  .metric-val { color:var(--text); font-size:13px; }
  .metric-lbl { font-size:9px; letter-spacing:0.08em; text-transform:uppercase; }

  /* в”Ђв”Ђ TREE PANEL в”Ђв”Ђ */
  .tree-panel {
    background: var(--surface);
    border-right: 1px solid var(--border);
    overflow-y: auto;
    padding: 8px 0;
  }
  .tree-panel::-webkit-scrollbar { width:4px; }
  .tree-panel::-webkit-scrollbar-track { background:transparent; }
  .tree-panel::-webkit-scrollbar-thumb { background:var(--border2); border-radius:2px; }

  .tree-header {
    padding: 8px 16px 10px;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    margin-bottom: 4px;
  }

  /* Node row */
  .node {
    cursor: pointer;
    transition: background 0.1s;
  }
  .node:hover > .node-row { background: rgba(255,255,255,0.025); }
  .node.active > .node-row { background: var(--accent-dim); border-right: 2px solid var(--accent); }

  .node-row {
    display: flex;
    align-items: center;
    padding: 5px 14px;
    gap: 7px;
    min-height: 30px;
  }

  .node-indent {
    flex-shrink: 0;
    display: flex;
  }
  .indent-unit { width: 18px; flex-shrink:0; }

  /* Tree lines */
  .tree-vline {
    position: relative;
  }
  .tree-vline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--border2);
  }

  .tree-connector {
    width: 18px;
    height: 100%;
    position: relative;
    flex-shrink: 0;
  }
  .tree-connector::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 50%;
    width: 1px;
    background: var(--border2);
  }
  .tree-connector::after {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 10px;
    height: 1px;
    background: var(--border2);
  }

  .node-icon {
    width: 20px; height: 20px;
    border-radius: 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    flex-shrink: 0;
    font-weight: 700;
  }
  .icon-human { background: var(--human-dim); color: var(--human); border: 1px solid rgba(96,165,250,0.25); }
  .icon-assistant { background: var(--assistant-dim); color: var(--assistant); border: 1px solid rgba(52,211,153,0.25); }
  .icon-agent { background: var(--purple-dim); color: var(--purple); border: 1px solid rgba(167,139,250,0.25); }
  .icon-tool { background: var(--orange-dim); color: var(--orange); border: 1px solid rgba(251,146,60,0.25); }
  .icon-llm { background: var(--accent-dim); color: var(--accent); border: 1px solid rgba(79,142,247,0.25); }
  .icon-subagent { background: rgba(167,139,250,0.08); color: var(--purple); border: 1px solid rgba(167,139,250,0.15); }

  .node-name {
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 11.5px;
  }
  .node-name-muted { color: var(--muted); }

  .node-status {
    width: 6px; height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .st-ok { background: var(--green); }
  .st-err { background: var(--red); }

  .node-dur {
    color: var(--muted);
    font-size: 10px;
    flex-shrink: 0;
  }

  /* Collapse toggle */
  .collapse-btn {
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    font-size: 11px;
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border-radius: 3px;
    transition: all 0.15s;
  }
  .collapse-btn:hover { background: var(--surface2); color: var(--text); }
  .collapse-btn.collapsed { transform: rotate(-90deg); }

  .node-children {
    overflow: hidden;
    transition: max-height 0.25s ease;
  }
  .node-children.collapsed {
    max-height: 0 !important;
  }

  /* в”Ђв”Ђ DETAIL PANEL в”Ђв”Ђ */
  .detail-panel {
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }
  .detail-panel::-webkit-scrollbar { width:4px; }
  .detail-panel::-webkit-scrollbar-track { background:transparent; }
  .detail-panel::-webkit-scrollbar-thumb { background:var(--border2); border-radius:2px; }

  .detail-header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 10px;
    position: sticky;
    top: 0;
    z-index: 10;
    flex-shrink: 0;
  }
  .detail-title { font-family:'Syne',sans-serif; font-size:15px; font-weight:700; }

  .chip-model { display:inline-flex; align-items:center; gap:4px; padding:2px 8px; border-radius:3px; font-size:10px; color:var(--accent); border:1px solid rgba(79,142,247,0.2); background:var(--accent-dim); }

  .detail-body {
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Sections */
  .section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }
  .section-head {
    padding: 9px 14px;
    font-size: 9px;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: var(--muted);
    background: var(--surface2);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .section-head .dot { width:5px; height:5px; border-radius:50%; background:currentColor; }
  .section-content {
    padding: 14px;
    font-size: 12px;
    line-height: 1.7;
  }

  .text-block {
    background: var(--surface2);
    border: 1px solid var(--border2);
    border-radius: 6px;
    padding: 12px 14px;
    font-size: 12px;
    line-height: 1.7;
  }
  .text-block pre {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    white-space: pre-wrap;
    word-break: break-all;
  }

  .reasoning-label {
    display: inline-block;
    background: var(--surface2);
    padding: 1px 6px;
    font-size: 8px;
    letter-spacing: 0.12em;
    color: var(--yellow);
    border: 1px solid rgba(251,191,36,0.2);
    border-radius: 3px;
    margin-bottom: 8px;
    text-transform: uppercase;
  }

  .reasoning-text { color: var(--muted); }
  .reasoning-text em { color: var(--text); font-style: normal; }

  /* Meta grid */
  .meta-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .meta-chip {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--muted);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 6px 12px;
  }
  .meta-chip b { font-weight:500; }
  .meta-chip .v-accent { color:var(--accent); }
  .meta-chip .v-green { color:var(--green); }
  .meta-chip .v-red { color:var(--red); }
  .meta-chip .v-orange { color:var(--orange); }

  /* Human message special */
  .human-message {
    font-size: 14px;
    line-height: 1.7;
    color: var(--text);
    padding: 4px 0;
  }

  /* Empty state */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: var(--muted);
    gap: 8px;
    font-size: 12px;
  }
  .empty-state-icon { font-size: 28px; opacity: 0.3; margin-bottom: 4px; }

  ::-webkit-scrollbar { width:5px; height:5px; }
  ::-webkit-scrollbar-track { background:transparent; }
  ::-webkit-scrollbar-thumb { background:var(--border2); border-radius:3px; }
</style>
</head>
