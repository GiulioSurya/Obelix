        <div class="section-head"><div class="dot" style="color:${dotColor}"></div>Output</div>
        <div class="section-content">
          <div class="text-block"><pre style="font-family:'JetBrains Mono',monospace;font-size:11px;white-space:pre-wrap;word-break:break-all;${outColor}">${esc(d.output)}</pre></div>
        </div>
      </div>`;
  }

  let reasoningHtml = '';
  if (d.reasoning) {
    reasoningHtml = `
      <div class="section">
        <div class="section-head"><div class="dot" style="color:var(--yellow)"></div>Metadata / Reasoning</div>
        <div class="section-content">
          <div class="reasoning-label">Thinking</div>
          <div class="reasoning-text">${d.reasoning}</div>
        </div>
      </div>`;
  }

  panel.innerHTML = `
    <div class="detail-header">
      <div class="node-icon ${iconClass}" style="width:24px;height:24px;font-size:10px;">${iconLetter}</div>
      <div class="detail-title">${d.name}</div>
      <div class="badge" style="${badgeStyle};font-size:10px;padding:2px 8px;border-radius:4px;">${badgeText}</div>
    </div>
    <div class="detail-body">
      <div class="meta-grid">${metaHtml}</div>
      ${inputHtml}
      ${outputHtml}
      ${reasoningHtml}
    </div>`;
}

// Select first node by default
select('human1', null);
</script>
</body>
</html>